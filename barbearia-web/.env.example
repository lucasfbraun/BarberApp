# =====================================================================
# Template de variaveis de ambiente — COPIE para .env.local e preencha.
# NUNCA coloque segredos reais neste arquivo (.env.example e versionado).
# Arquivos .env e .env.local sao ignorados pelo Git.
# =====================================================================

# Conexao com o banco (Postgres). Em producao, use a connection string do provedor.
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require"

# Segredo de assinatura do NextAuth (JWT).
# Gere um valor forte e unico por ambiente:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NUNCA use um placeholder em producao.
NEXTAUTH_SECRET="GERE_UM_SEGREDO_FORTE_E_UNICO"

# URL publica da aplicacao (sem barra no final).
NEXTAUTH_URL="http://localhost:3000"
